# Eigener API-Key zum Absichern deiner /search und /openai/tool_schema Endpoints.
# Wird von Clients als HTTP-Header `X-API-Key` mitgesendet.
API_KEY=dein-selbst-gewaehlter-secret-token

# Qdrant Cloud — Vektor-Datenbank
QDRANT_ENDPOINT=https://xxxxxxxx.cloud.qdrant.io:6333
QDRANT_API_KEY=...

# Anthropic — Query Expansion (Claude Sonnet)
ANTHROPIC_API_KEY=sk-ant-...

# Mixedbread — Query Embedding (mxbai-embed-de-large-v1)
MIXEDBREAD_API_KEY=mxb_...

# Voyage — Reranking (rerank-2.5)
VOYAGE_API_KEY=pa-...

# Cohere nur noetig, wenn du auf rerank-v3.5 zurueckfallen willst (optional).
COHERE_API_KEY=...

# Railway setzt PORT automatisch; lokal default 8080.
# PORT=8080
